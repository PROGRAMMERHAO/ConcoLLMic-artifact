    import signal
    import subprocess
    import tempfile
    import os

    # Create a temporary file with bc code
    # This file will be passed as a command-line argument to bc
    with tempfile.NamedTemporaryFile(mode='w', suffix='.bc', delete=False) as f:
        temp_filename = f.name
        # Write bc code to the file
        f.write("435 / 4 + 6 - 3421\n")
        f.write("quit\n")
    
    try:
        # Run bc with the filename as a command-line argument
        # This satisfies the constraint: argc >= 2, and file_names != NULL
        result = subprocess.run(
            ["./bc/bc", temp_filename],
            input="",  # No stdin input needed since we're reading from file
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=timeout,
        )
        # return stderr and the returncode
        return result.stderr, result.returncode
    except subprocess.TimeoutExpired as e:
        # Timeout occurred, also ensure to return stderr captured before timeout and return code -signal.SIGKILL
        return e.stderr, -signal.SIGKILL
    except Exception as e:
        # ensure to raise the error if run failed
        raise e
    finally:
        # Clean up the temporary file
        if os.path.exists(temp_filename):
            os.unlink(temp_filename)
