2026-04-17 15:04:09 | DEBUG | Solve result: is_satisfiable=True, python_execution=def execute_program(timeout: int) -> tuple[str, int]:
    import signal
    import subprocess
    import tempfile
    import os

    # To reach the math library loading branch, we need:
    # 1. The -l flag to set use_math = TRUE
    # 2. A file argument (not stdin) so is_std_in = FALSE
    # 3. first_file will be TRUE initially
    
    # Create a temporary file with bc commands
    with tempfile.NamedTemporaryFile(mode='w', suffix='.bc', delete=False) as f:
        f.write("435 / 4 + 6 - 3421\n")
        f.write("quit\n")
        temp_file = f.name
    
    try:
        # Invoke bc with -l flag (math library) and the temporary file
        result = subprocess.run(
            ["./bc/bc", "-l", temp_file],
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=timeout,
        )
        # return stderr and the returncode
        return result.stderr, result.returncode
    except subprocess.TimeoutExpired as e:
        # Timeout occurred, also ensure to return stderr captured before timeout and return code -signal.SIGKILL
        return e.stderr if e.stderr else "", -signal.SIGKILL
    except Exception as e:
        # ensure to raise the error if run failed
        raise e
    finally:
        # Clean up the temporary file
        if os.path.exists(temp_file):
            os.unlink(temp_file)
