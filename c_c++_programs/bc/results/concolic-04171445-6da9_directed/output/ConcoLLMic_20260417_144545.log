import pty
import os
import select
import signal
import subprocess

# Test if we can use pty to make isatty return true
def test_pty_approach():
    """Test that pty makes isatty return true"""
    
    # Create a simple test program that checks isatty
    test_code = """
import sys
print(f"stdin isatty: {sys.stdin.isatty()}")
print(f"stdout isatty: {sys.stdout.isatty()}")
"""
    
    # Test 1: Normal subprocess (should be False)
    print("Test 1: Normal subprocess.run with pipes")
    result = subprocess.run(
        ["python3", "-c", test_code],
        capture_output=True,
        text=True
    )
    print(result.stdout)
    
    # Test 2: Using pty (should be True)
    print("\nTest 2: Using pty")
    master, slave = pty.openpty()
    
    try:
        proc = subprocess.Popen(
            ["python3", "-c", test_code],
            stdin=slave,
            stdout=slave,
            stderr=subprocess.PIPE,
            text=True
        )
        
        os.close(slave)  # Close slave in parent
        
        # Read output from master
        output = b""
        while True:
            try:
                ready, _, _ = select.select([master], [], [], 0.1)
                if ready:
                    chunk = os.read(master, 1024)
                    if not chunk:
                        break
                    output += chunk
                else:
                    # Check if process has finished
                    if proc.poll() is not None:
                        # Try one more read
                        try:
                            chunk = os.read(master, 1024)
                            output += chunk
                        except:
                            pass
                        break
            except OSError:
                break
        
        proc.wait()
        os.close(master)
        
        print(output.decode('utf-8', errors='replace'))
        
    except Exception as e:
        print(f"Error: {e}")
        os.close(master)

test_pty_approach()

