2026-04-17 14:54:48 | DEBUG | Solve result: is_satisfiable=True, python_execution=def execute_program(timeout: int) -> tuple[str, int]:
    import signal
    import subprocess
    import pty
    import os
    import select
    import time

    commands = ["435 / 4 + 6 - 3421", "quit"]
    input_str = "\n".join(commands) + "\n"

    # Create a pseudo-terminal to make isatty() return true
    master, slave = pty.openpty()
    
    try:
        # Start bc with stdin/stdout connected to the pty slave
        proc = subprocess.Popen(
            ["./bc/bc"],
            stdin=slave,
            stdout=slave,
            stderr=subprocess.PIPE,
            encoding="utf-8",
            errors="replace"
        )
        
        # Close slave fd in parent process (child has its own copy)
        os.close(slave)
        
        # Send input to the master side of the pty
        input_bytes = input_str.encode('utf-8')
        os.write(master, input_bytes)
        
        # Wait for process to complete with timeout
        start_time = time.time()
        stderr_output = ""
        
        try:
            # Wait for process with timeout
            proc.wait(timeout=timeout)
            stderr_output = proc.stderr.read() if proc.stderr else ""
            returncode = proc.returncode
            
        except subprocess.TimeoutExpired:
            # Kill the process on timeout
            proc.kill()
            proc.wait()
            stderr_output = proc.stderr.read() if proc.stderr else ""
            returncode = -signal.SIGKILL
        
        finally:
            # Clean up
            os.close(master)
        
        return stderr_output, returncode
        
    except Exception as e:
        # Clean up on error
        try:
            os.close(master)
        except:
            pass
        raise e
