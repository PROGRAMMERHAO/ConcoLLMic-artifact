# Let me test a PTY-based solution to verify it works
import pty
import os
import subprocess
import signal
import select

def execute_program_pty(timeout: int) -> tuple[str, int]:
    """Test PTY-based execution"""
    commands = ["435 / 4 + 6 - 3421", "quit"]
    input_str = "\n".join(commands) + "\n"
    
    # Create a pseudo-terminal
    master, slave = pty.openpty()
    
    try:
        # Start the process with stdin/stdout connected to the PTY slave
        process = subprocess.Popen(
            ["echo", "test"],  # Using echo for testing
            stdin=slave,
            stdout=slave,
            stderr=subprocess.PIPE,
            encoding="utf-8",
            errors="replace",
        )
        
        # Close the slave fd in the parent process
        os.close(slave)
        
        # Write input to the master side of the PTY
        os.write(master, input_str.encode('utf-8'))
        
        # Wait for process to complete with timeout
        try:
            stderr = process.communicate(timeout=timeout)[1]
            returncode = process.returncode
        except subprocess.TimeoutExpired:
            process.kill()
            stderr = process.stderr.read() if process.stderr else ""
            returncode = -signal.SIGKILL
        
        return stderr, returncode
        
    finally:
        # Clean up
        os.close(master)

# Test the structure
print("PTY-based execution structure is valid")

