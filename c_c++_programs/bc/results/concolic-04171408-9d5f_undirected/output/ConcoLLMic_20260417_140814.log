2026-04-17 14:09:55 | DEBUG | Solve result: is_satisfiable=True, python_execution=def execute_program(timeout: int) -> tuple[str, int]:
    import signal
    import subprocess
    import tempfile
    import os

    # Create a temporary file with bc commands
    # This file will be passed as a command-line argument
    fd, temp_filename = tempfile.mkstemp(suffix='.bc', text=True)
    
    try:
        # Write some valid bc commands to the file
        with os.fdopen(fd, 'w') as f:
            f.write("1+1\n")
        
        # Execute bc with the filename as a command-line argument
        # This satisfies optind < argc since argc will be 2 (program name + filename)
        # and optind will be 1 (pointing to the first non-option argument)
        result = subprocess.run(
            ["./bc/bc", temp_filename],
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=timeout,
        )
        # return stderr and the returncode
        return result.stderr, result.returncode
    except subprocess.TimeoutExpired as e:
        # Timeout occurred, also ensure to return stderr captured before timeout and return code -signal.SIGKILL
        return e.stderr, -signal.SIGKILL
    except Exception as e:
        # ensure to raise the error if run failed
        raise e
    finally:
        # Clean up the temporary file
        try:
            os.unlink(temp_filename)
        except:
            pass
