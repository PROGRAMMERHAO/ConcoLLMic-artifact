def execute_program(timeout: int) -> tuple[str, int]:
    import signal
    import subprocess
    import tempfile

    # Create file content with many occurrences of 'a' to trigger capacity expansion
    # 300 lines of "aaaa\n" = 1500 bytes
    # Initial capacity = max(1000, 1500/1000) = 1000
    # Number of 'a' matches = 300 * 4 = 1200 (exceeds capacity, triggers expansion)
    file_data = "aaaa\n" * 300

    # create a temporary file
    with tempfile.NamedTemporaryFile(mode="w") as temp_file:
        # write file data to file
        temp_file.write(file_data)
        temp_file.flush()
        temp_file_path = temp_file.name
        try:
            # Search for 'a' instead of 'test' to get many matches
            result = subprocess.run(
                ["./krep", "-m", "3", "a", temp_file_path],
                capture_output=True,
                encoding="utf-8",
                errors="replace",
                timeout=timeout,
            )
            # return stderr and the returncode
            return result.stderr, result.returncode
        except subprocess.TimeoutExpired as e:
            # Timeout occurred, also ensure to return stderr captured before timeout and return code -signal.SIGKILL
            return e.stderr, -signal.SIGKILL
        except Exception as e:
            # ensure to raise the error if run failed
            raise e

