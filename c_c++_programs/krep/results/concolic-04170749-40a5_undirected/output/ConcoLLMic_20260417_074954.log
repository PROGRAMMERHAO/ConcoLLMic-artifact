def execute_program(timeout: int) -> tuple[str, int]:
    import signal
    import subprocess
    import tempfile

    # Create a file with a single very long line (600,000 'a' characters, no newline)
    # This will exceed LINE_BUFFER_INITIAL_SIZE (512KB = 524,288 bytes) when formatted for output
    # triggering buffer reallocation in ensure_line_buffer_capacity
    file_data = "a" * 600000

    # create a temporary file
    with tempfile.NamedTemporaryFile(mode="w") as temp_file:
        # write file data to file
        temp_file.write(file_data)
        temp_file.flush()
        temp_file_path = temp_file.name
        try:
            # Search for 'a' to match the long line
            # Using -m 3 to limit matches (though the line itself is what matters for buffer size)
            result = subprocess.run(
                ["./krep", "-m", "3", "a", temp_file_path],
                capture_output=True,
                encoding="utf-8",
                errors="replace",
                timeout=timeout,
            )
            # return stderr and the returncode
            return result.stderr, result.returncode
        except subprocess.TimeoutExpired as e:
            # Timeout occurred, also ensure to return stderr captured before timeout and return code -signal.SIGKILL
            return e.stderr, -signal.SIGKILL
        except Exception as e:
            # ensure to raise the error if run failed
            raise e

